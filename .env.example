# ============================================================
# SeguimientoPro — Variables de entorno
# Copia este archivo como .env.local y completa los valores
# NUNCA commitear .env.local al repositorio
# ============================================================

# ── Supabase (OBLIGATORIO) ───────────────────────────────────
# Encontrar en: supabase.com → proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key — usado por el webhook de Wompi para actualizar el plan
# sin sesión de usuario. NUNCA exponer al frontend (sin prefijo NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Analytics (opcional) ──────────────────────────────────────
# Google Analytics 4 — Measurement ID en GA4 → Admin → Data Streams
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Pagos: Wompi (plan PRO) ───────────────────────────────────
# Encontrar en: comercios.wompi.co → Desarrolladores → Llaves de API
# Usa las llaves "_test_" en sandbox y "_prod_" solo en producción.
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxxxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxxxxxxxxxxxxxxxxxx
# Encontrar en: comercios.wompi.co → Desarrolladores → Eventos
WOMPI_EVENTS_SECRET=test_events_xxxxxxxxxxxxxxxxxxxxx

# ── Producción (Vercel configura esto automáticamente) ───────
# VERCEL_URL se inyecta automáticamente en Vercel
